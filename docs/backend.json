
{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier in the network.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string", "enum": ["chocolate", "cosmetics", "detergents"] } },
        "productsOffered": { "type": "array", "items": { "type": "string" } },
        "leadTime": { "type": "number" },
        "lastStockSubmission": { "type": "string", "format": "date-time" },
        "contractStatus": { "type": "string", "enum": ["active", "pending", "expired"] },
        "ratings": {
          "type": "object",
          "properties": {
            "frequency": { "type": "number" },
            "speed": { "type": "number" },
            "price": { "type": "number" }
          }
        },
        "interactionNotes": { "type": "object", "description": "Notes keyed by department ID" },
        "notes": { "type": "string" }
      },
      "required": ["name", "email", "departments"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A lead or existing customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string", "enum": ["chocolate", "cosmetics", "detergents"] } },
        "interestedProducts": { "type": "array", "items": { "type": "string" } },
        "lastReplyDate": { "type": "string", "format": "date-time" },
        "accountStatus": { "type": "string", "enum": ["prospect", "active", "key account"] },
        "ratings": {
          "type": "object",
          "properties": {
            "responseTime": { "type": "number" },
            "activity": { "type": "number" },
            "volume": { "type": "number" }
          }
        },
        "interactionNotes": { "type": "object", "description": "Notes keyed by department ID" },
        "notes": { "type": "string" }
      },
      "required": ["name", "email", "departments"]
    },
    "UploadLog": {
      "title": "Upload Log",
      "description": "Record of a bulk data upload batch.",
      "type": "object",
      "properties": {
        "fileName": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "totalRows": { "type": "number" },
        "successCount": { "type": "number" },
        "failCount": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "department": { "type": "string" },
        "type": { "type": "string", "enum": ["suppliers", "buyers"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Global suppliers." },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer profiles." },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog." },
    "/stocks/{stockId}": { "schema": "Stock", "description": "Supplier inventory entries." },
    "/uploadLogs/{logId}": { "schema": "UploadLog", "description": "History of bulk uploads." }
  }
}
