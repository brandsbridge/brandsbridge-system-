
{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier in the network.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "department": { "type": "string", "enum": ["chocolate", "cosmetics", "detergents"] },
        "productsOffered": { "type": "array", "items": { "type": "string" } },
        "leadTime": { "type": "number" },
        "lastStockSubmission": { "type": "string", "format": "date-time" },
        "contractStatus": { "type": "string", "enum": ["active", "pending", "expired"] },
        "ratings": {
          "type": "object",
          "properties": {
            "frequency": { "type": "number" },
            "speed": { "type": "number" },
            "price": { "type": "number" }
          }
        },
        "notes": { "type": "string" }
      },
      "required": ["name", "email", "department"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A lead or existing customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "department": { "type": "string", "enum": ["chocolate", "cosmetics", "detergents"] },
        "interestedProducts": { "type": "array", "items": { "type": "string" } },
        "lastReplyDate": { "type": "string", "format": "date-time" },
        "accountStatus": { "type": "string", "enum": ["prospect", "active", "key account"] },
        "ratings": {
          "type": "object",
          "properties": {
            "responseTime": { "type": "number" },
            "activity": { "type": "number" },
            "volume": { "type": "number" }
          }
        },
        "notes": { "type": "string" }
      },
      "required": ["name", "email", "department"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "department": { "type": "string", "enum": ["chocolate", "cosmetics", "detergents"] },
        "imageUrl": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isWatch": { "type": "boolean" },
        "isBestDealToday": { "type": "boolean" },
        "margin": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "department"]
    },
    "Stock": {
      "title": "Stock",
      "description": "Inventory level for a product from a specific supplier.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "supplierId": { "type": "string" },
        "department": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "leadTime": { "type": "number" }
      },
      "required": ["productId", "supplierId", "quantity", "price"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Global suppliers." },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer profiles." },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog." },
    "/stocks/{stockId}": { "schema": "Stock", "description": "Supplier inventory entries." }
  }
}
