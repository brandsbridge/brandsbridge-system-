
{
  "entities": {
    "Supplier": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Supplier",
      "type": "object",
      "description": "Represents a manufacturing or trading partner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "recordStatus": { "type": "string" },
        "dataCompleteness": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Represents a B2B buyer.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "accountStatus": { "type": "string" },
        "accountHealth": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "discountTotal": { "type": "number" },
        "shippingCharges": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue", "void"] },
        "sentStatus": { "type": "string", "enum": ["draft", "sent"] },
        "dueDate": { "type": "string" },
        "department": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "isProforma": { "type": "boolean" },
        "language": { "type": "string", "enum": ["en", "ar"] },
        "ccEmails": { "type": "string" },
        "paymentLink": { "type": "string" },
        "internalNotes": { "type": "string" },
        "termsAndConditions": { "type": "string" },
        "customFields": { "type": "array", "items": { "type": "object" } },
        "stampUrl": { "type": "string" },
        "originalImageUrl": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["number", "customerName", "total", "status", "department"]
    },
    "InvoiceScan": {
      "title": "Invoice Scan Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "scannedAt": { "type": "string", "format": "date-time" },
        "scannedBy": { "type": "string" },
        "accuracyRate": { "type": "number" },
        "status": { "type": "string", "enum": ["completed", "failed"] },
        "originalImageUrl": { "type": "string" }
      }
    },
    "RecurringInvoice": {
      "title": "Recurring Invoice Template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "templateName": { "type": "string" },
        "originalInvoiceId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly", "yearly"] },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "lastGenerated": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "paused", "completed"] },
        "amount": { "type": "number" },
        "autoSend": { "type": "boolean" }
      }
    },
    "CreditNote": {
      "title": "Credit Note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "invoiceId": { "type": "string" },
        "amount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed", "void"] },
        "date": { "type": "string" }
      }
    },
    "CustomerAdvance": {
      "title": "Customer Advance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "amount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "reference": { "type": "string" },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string" }
      }
    },
    "VendorCredit": {
      "title": "Vendor Credit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "amount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "reason": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partyName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["received", "made"] },
        "method": { "type": "string" },
        "reference": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["partyName", "amount", "type", "department"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "supplierName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["number", "supplierName", "total", "status", "department"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/suppliers/{id}", "definition": { "entityName": "Supplier", "description": "Global suppliers" } },
      { "path": "/customers/{id}", "definition": { "entityName": "Customer", "description": "B2B Customers" } },
      { "path": "/invoices/{id}", "definition": { "entityName": "Invoice", "description": "Sales invoices" } },
      { "path": "/invoice_scans/{id}", "definition": { "entityName": "InvoiceScan", "description": "AI scanning logs" } },
      { "path": "/recurring_invoices/{id}", "definition": { "entityName": "RecurringInvoice", "description": "Auto-billing templates" } },
      { "path": "/credit_notes/{id}", "definition": { "entityName": "CreditNote", "description": "Sales returns/credits" } },
      { "path": "/customer_advances/{id}", "definition": { "entityName": "CustomerAdvance", "description": "Pre-payments" } },
      { "path": "/vendor_credits/{id}", "definition": { "entityName": "VendorCredit", "description": "Supplier credits" } },
      { "path": "/payments/{id}", "definition": { "entityName": "Payment", "description": "Financial settlements" } },
      { "path": "/purchase_orders/{id}", "definition": { "entityName": "PurchaseOrder", "description": "Procurement orders" } },
      { "path": "/journals/{id}", "definition": { "entityName": "JournalEntry", "description": "General journal entries" } },
      { "path": "/campaigns/{id}", "definition": { "entityName": "Campaign", "description": "Marketing outreach" } },
      { "path": "/communication_logs/{id}", "definition": { "entityName": "CommunicationLog", "description": "Email audit trail" } },
      { "path": "/app_roles_admin/{userId}", "definition": { "entityName": "AdminRole", "description": "Access control" } }
    ]
  }
}
