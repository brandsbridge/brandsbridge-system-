
{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "type": "object",
      "description": "Represents a manufacturing or trading partner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "vatId": { "type": "string" },
        "bdoNumber": { "type": "string" },
        "bankInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "bic": { "type": "string" },
            "iban": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "address": { "type": "string" },
        "vatId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product Catalog Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gtin": { "type": "string", "description": "Bar code / GTIN-13" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "packing": { "type": "number", "description": "pcs per case" },
        "weightNet": { "type": "number", "description": "kg per case" },
        "weightGross": { "type": "number" }
      }
    },
    "Invoice": {
      "title": "Professional Trade Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string", "description": "Format: TYPE/SEQ/MM/YYYY" },
        "type": { "type": "string", "enum": ["EXP", "INV", "PRO", "CN"] },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue", "cancelled"] },
        "dateIssue": { "type": "string" },
        "dateSale": { "type": "string" },
        "sellerId": { "type": "string" },
        "buyerId": { "type": "string" },
        "recipientId": { "type": "string" },
        "deliveryTerms": { "type": "string", "enum": ["CIF", "FOB", "EXW", "DDP"] },
        "destinationCountry": { "type": "string" },
        "shippingInfo": {
          "type": "object",
          "properties": {
            "shipmentDate": { "type": "string" },
            "truckNumber": { "type": "string" },
            "sealNumber": { "type": "string" },
            "containerNumber": { "type": "string" },
            "exchangeRate": { "type": "number" },
            "orderNumber": { "type": "string" }
          }
        },
        "lineItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "gtin": { "type": "string" },
              "description": { "type": "string" },
              "packing": { "type": "number" },
              "quantityCs": { "type": "number" },
              "quantityPcs": { "type": "number" },
              "priceNet": { "type": "number" },
              "vatRate": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "totals": {
          "type": "object",
          "properties": {
            "net": { "type": "number" },
            "vat": { "type": "number" },
            "gross": { "type": "number" },
            "weightNet": { "type": "number" },
            "weightGross": { "type": "number" },
            "totalBoxes": { "type": "number" }
          }
        },
        "paymentTerms": {
          "type": "object",
          "properties": {
            "method": { "type": "string" },
            "dueDate": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/products/{id}", "definition": { "entityName": "Product", "description": "Global product catalog" } },
      { "path": "/invoices/{id}", "definition": { "entityName": "Invoice", "description": "Sales and export invoices" } },
      { "path": "/suppliers/{id}", "definition": { "entityName": "Supplier", "description": "Trading entities" } },
      { "path": "/customers/{id}", "definition": { "entityName": "Customer", "description": "Buyers and recipients" } }
    ]
  }
}
