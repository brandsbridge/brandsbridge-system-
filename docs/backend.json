
{
  "entities": {
    "Supplier": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Supplier",
      "type": "object",
      "description": "Represents a manufacturing or trading partner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "recordStatus": { "type": "string" },
        "dataCompleteness": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Represents a B2B buyer.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "accountStatus": { "type": "string" },
        "accountHealth": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "department": { "type": "string" }
      },
      "required": ["id", "name", "department"]
    },
    "Stock": {
      "title": "Stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "supplierId": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "leadTime": { "type": "number" }
      },
      "required": ["id", "productId", "supplierId", "price", "quantity"]
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string" }
      },
      "required": ["id", "name", "company", "stage"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "assignee": { "type": "string" },
        "dueDate": { "type": "string" }
      },
      "required": ["id", "title", "status"]
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "department": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "sent": { "type": "number" },
            "replied": { "type": "number" },
            "revenue": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/suppliers/{id}", "definition": { "entityName": "Supplier", "description": "Global suppliers" } },
      { "path": "/customers/{id}", "definition": { "entityName": "Customer", "description": "B2B Customers" } },
      { "path": "/products/{id}", "definition": { "entityName": "Product", "description": "Managed products" } },
      { "path": "/stocks/{id}", "definition": { "entityName": "Stock", "description": "Inventory levels" } },
      { "path": "/leads/{id}", "definition": { "entityName": "Lead", "description": "CRM Leads" } },
      { "path": "/tasks/{id}", "definition": { "entityName": "Task", "description": "Project tasks" } },
      { "path": "/campaigns/{id}", "definition": { "entityName": "Campaign", "description": "Outreach campaigns" } },
      { "path": "/app_roles_admin/{userId}", "definition": { "entityName": "AdminRole", "description": "Access control" } }
    ]
  }
}
