{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "Represents a business supplier providing products.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "country", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "accountStatus": { "type": "string" },
        "totalRevenue": { "type": "number" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "department": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerName": { "type": "string" },
        "totalUSD": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partyName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "supplierName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "assignee": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "targetMarket": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/suppliers": {
      "schema": { "$ref": "#/backend/entities/Supplier" },
      "description": "Global suppliers collection"
    },
    "/customers": {
      "schema": { "$ref": "#/backend/entities/Customer" },
      "description": "Global customers collection"
    },
    "/products": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Product catalog"
    },
    "/invoices": {
      "schema": { "$ref": "#/backend/entities/Invoice" },
      "description": "Sales invoices ledger"
    },
    "/payments": {
      "schema": { "$ref": "#/backend/entities/Payment" },
      "description": "Financial settlements ledger"
    },
    "/purchase_orders": {
      "schema": { "$ref": "#/backend/entities/PurchaseOrder" },
      "description": "Procurement orders"
    },
    "/tasks": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "Project management tasks"
    },
    "/campaigns": {
      "schema": { "$ref": "#/backend/entities/Campaign" },
      "description": "Marketing campaigns"
    }
  }
}