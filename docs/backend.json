
{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "Represents a business supplier providing products.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "recordStatus": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "specializedProducts": { "type": "array", "items": { "type": "string" } },
        "pricing": {
          "type": "object",
          "properties": {
            "tier": { "type": "string" },
            "leadTime": { "type": "number" },
            "moq": { "type": "string" },
            "mov": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "country", "createdAt"]
    },
    "SupplierAttachment": {
      "title": "Supplier Attachment",
      "description": "Metadata for a file uploaded for a supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileType": { "type": "string" },
        "storagePath": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" },
        "supplierId": { "type": "string" }
      },
      "required": ["fileName", "fileUrl", "supplierId"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "accountStatus": { "type": "string" },
        "accountHealth": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "assignedManager": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "totalUSD": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "dateIssue": { "type": "string" },
        "department": { "type": "string" },
        "lineItems": { "type": "array", "items": { "type": "object" } },
        "totals": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partyName": { "type": "string" },
        "vendorId": { "type": "string" },
        "amount": { "type": "number" },
        "totalUSD": { "type": "number" },
        "currency": { "type": "string" },
        "type": { "type": "string" },
        "method": { "type": "string" },
        "reference": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "department": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "assignee": { "type": "string" },
        "dueDate": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "targetMarket": { "type": "string" },
        "type": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gtin": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "packing": { "type": "number" },
        "department": { "type": "string" }
      }
    },
    "Stock": {
      "title": "Stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "supplierId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "leadTime": { "type": "number" },
        "department": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "vendorName": { "type": "string" },
        "accountName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "department": { "type": "string" }
      }
    },
    "Journal": {
      "title": "Journal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" }
      }
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/suppliers": {
      "schema": { "$ref": "#/backend/entities/Supplier" },
      "description": "Global suppliers directory"
    },
    "/supplier_attachments": {
      "schema": { "$ref": "#/backend/entities/SupplierAttachment" },
      "description": "Metadata for files stored in Firebase Storage"
    },
    "/customers": {
      "schema": { "$ref": "#/backend/entities/Customer" },
      "description": "B2B customers registry"
    },
    "/invoices": {
      "schema": { "$ref": "#/backend/entities/Invoice" },
      "description": "Sales invoices ledger"
    },
    "/payments": {
      "schema": { "$ref": "#/backend/entities/Payment" },
      "description": "Settlement records"
    },
    "/purchase_orders": {
      "schema": { "$ref": "#/backend/entities/PurchaseOrder" },
      "description": "Procurement orders"
    },
    "/tasks": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "Workflow tasks"
    },
    "/campaigns": {
      "schema": { "$ref": "#/backend/entities/Campaign" },
      "description": "Marketing initiatives"
    },
    "/products": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Product catalog"
    },
    "/stocks": {
      "schema": { "$ref": "#/backend/entities/Stock" },
      "description": "Inventory stock levels"
    },
    "/expenses": {
      "schema": { "$ref": "#/backend/entities/Expense" },
      "description": "Operational expenses"
    },
    "/journals": {
      "schema": { "$ref": "#/backend/entities/Journal" },
      "description": "General ledger journal entries"
    },
    "/leads": {
      "schema": { "$ref": "#/backend/entities/Lead" },
      "description": "Sales CRM leads"
    }
  }
}
