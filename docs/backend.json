{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "type": "object",
      "description": "Represents a manufacturing or trading partner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "vatId": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "recordStatus": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "accountStatus": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product Catalog Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gtin": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Trade Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerName": { "type": "string" },
        "totalUSD": { "type": "number" },
        "status": { "type": "string" },
        "department": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Marketing Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "targetMarket": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/products/{id}", "definition": { "entityName": "Product", "description": "Global product catalog" } },
      { "path": "/invoices/{id}", "definition": { "entityName": "Invoice", "description": "Sales and export invoices" } },
      { "path": "/suppliers/{id}", "definition": { "entityName": "Supplier", "description": "Trading entities" } },
      { "path": "/customers/{id}", "definition": { "entityName": "Customer", "description": "Buyers and recipients" } },
      { "path": "/campaigns/{id}", "definition": { "entityName": "Campaign", "description": "Marketing outreach" } },
      { "path": "/purchase_orders/{id}", "definition": { "entityName": "PurchaseOrder", "description": "Supplier procurement" } },
      { "path": "/payments/{id}", "definition": { "entityName": "Payment", "description": "Financial settlements" } },
      { "path": "/expenses/{id}", "definition": { "entityName": "Expense", "description": "Operating costs" } },
      { "path": "/customer_advances/{id}", "definition": { "entityName": "CustomerAdvance", "description": "Pre-payments" } },
      { "path": "/credit_notes/{id}", "definition": { "entityName": "CreditNote", "description": "Sales returns" } },
      { "path": "/supplier_attachments/{id}", "definition": { "entityName": "Attachment", "description": "Partner docs" } }
    ]
  }
}