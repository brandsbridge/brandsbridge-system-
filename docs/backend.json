
{
  "entities": {
    "Supplier": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Supplier",
      "type": "object",
      "description": "Represents a manufacturing or trading partner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "recordStatus": { "type": "string" },
        "dataCompleteness": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "description": "Represents a B2B buyer.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "accountStatus": { "type": "string" },
        "accountHealth": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "dueDate": { "type": "string" },
        "department": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["number", "customerName", "total", "status", "department"]
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partyName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["received", "made"] },
        "method": { "type": "string" },
        "reference": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["partyName", "amount", "type", "department"]
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "supplierName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["number", "supplierName", "total", "status", "department"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "department": { "type": "string" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "accountCode": { "type": "string" },
              "accountName": { "type": "string" },
              "debit": { "type": "number" },
              "credit": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/suppliers/{id}", "definition": { "entityName": "Supplier", "description": "Global suppliers" } },
      { "path": "/customers/{id}", "definition": { "entityName": "Customer", "description": "B2B Customers" } },
      { "path": "/invoices/{id}", "definition": { "entityName": "Invoice", "description": "Sales invoices" } },
      { "path": "/payments/{id}", "definition": { "entityName": "Payment", "description": "Financial settlements" } },
      { "path": "/purchase_orders/{id}", "definition": { "entityName": "PurchaseOrder", "description": "Procurement orders" } },
      { "path": "/journals/{id}", "definition": { "entityName": "JournalEntry", "description": "General journal entries" } },
      { "path": "/app_roles_admin/{userId}", "definition": { "entityName": "AdminRole", "description": "Access control" } }
    ]
  }
}
