
{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "A verified manufacturer or trading partner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "priorityLevel": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "recordStatus": { "type": "string" },
        "internalRating": { "type": "number" },
        "dataCompleteness": { "type": "number" },
        "lastUpdatedBy": { "type": "string" },
        "lastUpdatedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "departments"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A B2B buyer or prospect.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "accountStatus": { "type": "string" },
        "accountHealth": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "assignedManager": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "dataCompleteness": { "type": "number" }
      },
      "required": ["name", "email", "departments"]
    },
    "Product": {
      "title": "Product",
      "description": "An item in the global catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "department": { "type": "string" },
        "margin": { "type": "number" },
        "isFeatured": { "type": "boolean" }
      }
    },
    "Stock": {
      "title": "Stock",
      "description": "Inventory availability from a specific supplier.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "supplierId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "leadTime": { "type": "number" },
        "department": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A marketing outreach initiative.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "department": { "type": "string" },
        "type": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "sent": { "type": "number" },
            "replied": { "type": "number" },
            "revenue": { "type": "number" }
          }
        }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "A sales opportunity in the CRM.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string" }
      }
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A completed transaction.",
      "type": "object",
      "properties": {
        "buyerName": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "totalRevenue": { "type": "number" },
        "netProfit": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "deliveryStatus": { "type": "string" },
        "date": { "type": "object" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "An operational task in the Kanban board.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "assignee": { "type": "string" },
        "dueDate": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Supplier directory." },
    "/customers/{customerId}": { "schema": "Customer", "description": "Buyer directory." },
    "/products/{productId}": { "schema": "Product", "description": "Global product list." },
    "/stocks/{stockId}": { "schema": "Stock", "description": "Inventory records." },
    "/campaigns/{campaignId}": { "schema": "Campaign", "description": "Marketing campaigns." },
    "/leads/{leadId}": { "schema": "Lead", "description": "CRM leads." },
    "/purchases/{purchaseId}": { "schema": "Purchase", "description": "Order history." },
    "/tasks/{taskId}": { "schema": "Task", "description": "Operational tasks." }
  }
}
