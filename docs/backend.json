{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "Manufacturing or trading partner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string", "description": "Owner UID" }
      }
    },
    "SupplierAttachment": {
      "title": "Supplier Attachment",
      "description": "Files uploaded for a supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "userId": { "type": "string" },
        "supplierId": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "B2B Buyer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "accountStatus": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "totalUSD": { "type": "number" },
        "status": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "total": { "type": "number" },
        "userId": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "value": { "type": "number" },
        "userId": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "custom"]
  },
  "firestore": {
    "/suppliers": { "schema": { "$ref": "#/backend/entities/Supplier" }, "description": "Supplier directory" },
    "/supplier_attachments": { "schema": { "$ref": "#/backend/entities/SupplierAttachment" }, "description": "File metadata" },
    "/customers": { "schema": { "$ref": "#/backend/entities/Customer" }, "description": "Customer registry" },
    "/invoices": { "schema": { "$ref": "#/backend/entities/Invoice" }, "description": "Sales ledger" },
    "/payments": { "schema": { "$ref": "#/backend/entities/Payment" }, "description": "Transaction logs" },
    "/purchase_orders": { "schema": { "$ref": "#/backend/entities/PurchaseOrder" }, "description": "Procurement" },
    "/tasks": { "schema": { "$ref": "#/backend/entities/Task" }, "description": "Workflow" },
    "/expenses": { "schema": { "$ref": "#/backend/entities/Expense" }, "description": "Operational spending" },
    "/recurring_invoices": { "schema": "object", "description": "Billing templates" },
    "/credit_notes": { "schema": "object", "description": "Sales returns" },
    "/customer_advances": { "schema": "object", "description": "Pre-payments" },
    "/vendor_credits": { "schema": "object", "description": "Supplier credits" },
    "/journals": { "schema": "object", "description": "General ledger" },
    "/leads": { "schema": { "$ref": "#/backend/entities/Lead" }, "description": "CRM leads" },
    "/campaigns": { "schema": { "$ref": "#/backend/entities/Campaign" }, "description": "Marketing" },
    "/market_assets": { "schema": "object", "description": "Department files" },
    "/products": { "schema": "object", "description": "Catalog" },
    "/stocks": { "schema": "object", "description": "Inventory levels" },
    "/communication_logs": { "schema": "object", "description": "Email tracking" },
    "/exchangeRatesHistory": { "schema": "object", "description": "FX logs" },
    "/system_config": { "schema": "object", "description": "App settings" },
    "/app_roles_admin": { "schema": "object", "description": "RBAC management" }
  }
}