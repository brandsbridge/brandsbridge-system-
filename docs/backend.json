{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "type": "object",
      "description": "Represents a manufacturing or trading partner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "natureOfBusiness": { "type": "string" },
        "recordStatus": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "accountStatus": { "type": "string" },
        "departments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product Catalog Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gtin": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Trade Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "customerName": { "type": "string" },
        "totalUSD": { "type": "number" },
        "status": { "type": "string" },
        "department": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Marketing Campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "targetMarket": { "type": "string" }
      }
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "supplierName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Settlement Record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "type": { "type": "string", "enum": ["received", "made"] }
      }
    },
    "Task": {
      "title": "Operational Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/suppliers/{id}": { "schema": { "$ref": "#/entities/Supplier" }, "description": "Global trading partners" },
    "/customers/{id}": { "schema": { "$ref": "#/entities/Customer" }, "description": "Corporate buyers" },
    "/products/{id}": { "schema": { "$ref": "#/entities/Product" }, "description": "Global product catalog" },
    "/invoices/{id}": { "schema": { "$ref": "#/entities/Invoice" }, "description": "Sales and export invoices" },
    "/campaigns/{id}": { "schema": { "$ref": "#/entities/Campaign" }, "description": "Marketing outreach" },
    "/purchase_orders/{id}": { "schema": { "$ref": "#/entities/PurchaseOrder" }, "description": "Supplier procurement" },
    "/payments/{id}": { "schema": { "$ref": "#/entities/Payment" }, "description": "Financial settlements" },
    "/tasks/{id}": { "schema": { "$ref": "#/entities/Task" }, "description": "Workflow management" }
  }
}