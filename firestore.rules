rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * 🔓 GLOBAL UNRESTRICTED ACCESS
     * Deployment triggered to ensure all new collections (campaigns, payments, etc.) 
     * are accessible across all market departments.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}