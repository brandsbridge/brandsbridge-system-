
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /app_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /communication_logs/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Business Data: Simplified for prototype productivity
    match /suppliers/{id} { allow read, write: if isSignedIn(); }
    match /customers/{id} { allow read, write: if isSignedIn(); }
    match /products/{id} { allow read, write: if isSignedIn(); }
    match /stocks/{id} { allow read, write: if isSignedIn(); }
    match /invoices/{id} { allow read, write: if isSignedIn(); }
    match /recurring_invoices/{id} { allow read, write: if isSignedIn(); }
    match /credit_notes/{id} { allow read, write: if isSignedIn(); }
    match /customer_advances/{id} { allow read, write: if isSignedIn(); }
    match /vendor_credits/{id} { allow read, write: if isSignedIn(); }
    match /payments/{id} { allow read, write: if isSignedIn(); }
    match /purchase_orders/{id} { allow read, write: if isSignedIn(); }
    match /journals/{id} { allow read, write: if isSignedIn(); }
    match /campaigns/{id} { allow read, write: if isSignedIn(); }
    match /leads/{id} { allow read, write: if isSignedIn(); }
    match /tasks/{id} { allow read, write: if isSignedIn(); }
    match /employees/{id} { allow read, write: if isSignedIn(); }
    match /uploadLogs/{id} { allow read, write: if isSignedIn(); }
    match /purchases/{id} { allow read, write: if isSignedIn(); }

    // Fallback
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
