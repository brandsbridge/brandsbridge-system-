rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY UPDATE: Triggered deployment to refresh permissions for all collections.
    // Explicitly allow any authenticated user to perform read and write operations.
    // This provides universal access for valid sessions while blocking public traffic.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}