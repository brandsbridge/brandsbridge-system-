rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deployment Timestamp: 2025-02-18T12:30:00Z
    // Optimized for BizFlow: Global authenticated access for team collaboration.

    /**
     * Helper to check if the session is authenticated.
     * Compatible with custom tokens and anonymous providers.
     */
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    /**
     * Helper to check for document ownership.
     * Requires a 'userId' field in the document matching the current user's uid.
     */
    function isOwner() {
      return isAuthenticated() && 
             resource != null && 
             resource.data.userId == request.auth.uid;
    }

    // Global Catch-all Rule for all collections
    // This handles: invoices, payments, suppliers, customers, purchase_orders, tasks, expenses, etc.
    match /{allPaths=**} {
      // 1. Allow any authenticated user to read, list, and create records.
      // This ensures all modules function correctly for team-wide visibility.
      allow read, list, create: if isAuthenticated();

      // 2. Restrict updates and deletions to the owner of the record.
      // This protects data integrity while allowing global reading.
      allow update, delete: if isOwner();
    }
    
    // Explicit overrides for system-critical paths if needed in the future
    match /system_config/{configId} {
       allow read, write: if isAuthenticated();
    }

    match /app_roles_admin/{userId} {
       allow read, write: if isAuthenticated();
    }
  }
}