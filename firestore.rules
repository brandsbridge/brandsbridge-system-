
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    // Admin Roles: Users can promote themselves during setup
    match /app_roles_admin/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Business Data: Allow read for all signed-in users, restrict write to Admins
    // This allows Managers and Viewers to see the dashboard while preventing unauthorized changes.
    match /suppliers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /customers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /products/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /stocks/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /leads/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /tasks/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /campaigns/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /purchases/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /invoices/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /payments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /purchase_orders/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /journals/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /uploadLogs/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /employees/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Fallback
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
