rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * 🔓 GLOBAL UNRESTRICTED ACCESS
     * Deployment refreshed to ensure all system collections (invoices, payments, tasks, etc.)
     * are permitted for the current session.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}