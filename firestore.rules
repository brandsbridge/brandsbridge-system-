rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deployment Timestamp: 2025-02-18T15:00:00Z
    // Optimized access policy for BizFlow: Global collaborative read/create with ownership-based mutations.

    /**
     * Helper to check if the session is authenticated.
     * Supports standard providers and custom token authentication.
     */
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    /**
     * Helper to check for document ownership.
     * Compares the 'userId' field in the document to the current requester's uid.
     */
    function isOwner() {
      return isAuthenticated() && 
             resource != null && 
             resource.data.userId == request.auth.uid;
    }

    // Catch-all rule for all collections ensures no module is accidentally blocked.
    match /{allPaths=**} {
      // 1. Allow all authenticated team members to read, list, and create.
      // This facilitates cross-departmental visibility and collaborative workflows.
      allow read, list, create: if isAuthenticated();

      // 2. Restrict updates and deletions to the owner of the specific record.
      // This protects data integrity by ensuring only the creator can modify their entries.
      allow update, delete: if isOwner();
    }
    
    // Explicit overrides for system-level configuration if required.
    match /system_config/{configId} {
       allow read, write: if isAuthenticated();
    }
  }
}