rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deployment Timestamp: 2025-02-18T11:00:00Z
    // Optimized for BizFlow: Permissive Read/Create for Authenticated users, Restricted Update/Delete.

    /**
     * Helper to check if the session is authenticated.
     * Compatible with custom tokens and anonymous providers.
     */
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    /**
     * Helper to check for document ownership.
     * Requires a 'userId' field in the document matching the current user's uid.
     */
    function isOwner() {
      return isAuthenticated() && 
             resource != null && 
             resource.data.userId == request.auth.uid;
    }

    // Global Catch-all Rule for all collections
    match /{allPaths=**} {
      // 1. Allow any authenticated user to read, list, and create records.
      // This ensures all modules (Finance, CRM, Ops) function for legitimate users.
      allow read, list, create: if isAuthenticated();

      // 2. Restrict updates and deletions to the owner of the record.
      // This protects data integrity while allowing collaborative viewing.
      allow update, delete: if isOwner();
    }
    
    // Explicit overrides for system-critical paths
    match /system_config/{configId} {
       allow read: if isAuthenticated();
       allow write: if isAuthenticated(); // Broad access for prototype settings
    }

    match /app_roles_admin/{userId} {
       allow read, write: if isAuthenticated(); // Broad access for prototype admin activation
    }
  }
}