rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REFRESH RULES: 2025-02-24T12:00:00Z
    // This rule allows any user with a valid Firebase Auth token (including anonymous)
    // to perform read and write operations on any document in the database.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}