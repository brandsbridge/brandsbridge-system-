rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deployment Timestamp: 2024-05-22T10:00:00Z
    // This rule set provides a global security policy for the BizFlow platform.

    /**
     * Helper to check if the session is authenticated.
     * Works with standard and custom token providers.
     */
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    /**
     * Helper to check for document ownership.
     * If a 'userId' field exists, it must match the current user's uid.
     */
    function isOwner() {
      return isAuthenticated() && 
             resource.data.userId == request.auth.uid;
    }

    // Global Catch-all Rule for all collections
    match /{allPaths=**} {
      // 1. Allow any authenticated user to read, list, and create records.
      // This prevents "Missing or insufficient permissions" on initial data loads.
      allow read, list, create: if isAuthenticated();

      // 2. Restrict updates and deletions to the owner of the record.
      // This ensures data integrity and prevents unauthorized modifications.
      allow update, delete: if isOwner();
    }
    
    // Explicit overrides for system-critical paths can be added here if needed.
    match /system_config/{configId} {
       allow read: if isAuthenticated();
       allow write: if isAuthenticated(); // Allow admins to refresh rates
    }
  }
}