rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * 🔐 AUTHENTICATED ACCESS ONLY
     * Ensures that all read/write operations require a valid Firebase Auth session.
     * Role-based visibility is further managed at the application logic layer.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}